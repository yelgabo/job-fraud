generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employer {
  id              String    @id @default(cuid())
  nameNormalized  String    @unique
  nameDisplay     String
  website         String?
  applicationUrl  String?
  addressRaw      String?
  checks          Json      @default("{}")
  checkedAt       DateTime?
  jobs            Job[]
  webSearchLogs   EmployerWebSearchLog[]
}

// Raw audit trail of the Claude web_search activity behind each employer verification.
// Append-only: one row per verifyEmployerWeb run (a --rejudge adds a new row, giving history).
// Kept OUT of Employer.checks so prod pages (which read checks on every render) never pull these
// large encrypted_content blobs; consumed only by a separate, non-prod audit UI.
model EmployerWebSearchLog {
  id          String   @id @default(cuid())
  employerId  String
  employer    Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
  capturedAt  DateTime @default(now())
  queries     Json     // string[] — the searches Claude ran (quick-scan convenience)
  blocks      Json     // raw server_tool_use(web_search) + web_search_tool_result blocks, incl. encrypted_content

  @@index([employerId, capturedAt])
}

model Job {
  workbcId          String    @id
  employerId        String?
  employer          Employer? @relation(fields: [employerId], references: [id], onDelete: SetNull)
  title             String
  location          String?
  salary            String?
  postedAt           String?
  sourceUrl         String
  descriptionMd     String
  externalApplyUrl  String?
  externalApplyHost String?
  atsProvider       String?
  externalApplyOk   Boolean?
  applicationFlags  Json      @default("[]")
  // NOC occupation classification (from WorkBC) + derived coarse job-type bucket for filtering
  // and analysis. nocCode/nocGroup are kept raw so finer breakdowns stay possible.
  nocCode           String?
  nocGroup          String?
  category          String?
  // Scoring fields are null until the `judge` phase evaluates the posting.
  fraudScore        Int?
  riskBand          String?
  reasoning         String?
  signals           Json?
  scoredAt          DateTime?
  scrapedAt         DateTime  @default(now())

  @@index([riskBand, fraudScore])
  @@index([scoredAt])
  @@index([category])
}
