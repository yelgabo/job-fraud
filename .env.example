# Postgres connection string. For local runs use Railway's DATABASE_PUBLIC_URL
# (TCP proxy host), not the *.railway.internal URL which only resolves inside Railway.
DATABASE_URL="postgresql://user:password@host:port/dbname"

# Anthropic API key — required by the scrape script (scoring). Not needed for `next build`.
ANTHROPIC_API_KEY="sk-ant-..."

# Optional: WorkBC search URL (defaults to software jobs, pagesize 50).
WORKBC_SEARCH_URL="https://www.workbc.ca/search-and-prepare-job/find-jobs#/job-search;search=software;pagesize=50;"

# Optional: polite User-Agent for Nominatim geocoding (ToS requires a real contact).
NOMINATIM_USER_AGENT="job-fraud/0.1 (github.com/yelnil)"
